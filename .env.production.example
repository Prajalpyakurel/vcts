APP_NAME="Valley College"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Create this database + user from cPanel > MySQL Databases first,
# then fill in the exact names cPanel generated (usually prefixed
# with your cPanel username, e.g. cpuser_valleycollege).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpuser_valleycollege
DB_USERNAME=cpuser_vcadmin
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BOOTSTRAP_PROVIDERS=bootstrap/providers.php

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

VITE_APP_NAME="${APP_NAME}"
